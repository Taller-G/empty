# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dasdasdd_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000

# CORS
CORS_ORIGIN=http://localhost:4200

# Security
JWT_SECRET=change_this_to_a_secure_random_string_in_production
JWT_EXPIRY=1h
